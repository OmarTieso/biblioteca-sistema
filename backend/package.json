{
  "name": "biblioteca-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env prod",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --coverageReporters=lcov --coverageReporters=cobertura --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@sentry/cloudflare": "^8.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "jest": "^29.0.0",
    "jest-junit": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "node",

    "transform": {},
    "collectCoverageFrom": ["src/services/**/*.js"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "cobertura"]
  }
}
